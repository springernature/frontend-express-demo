{
  "name": "frontend-techtest",
  "version": "0.0.0",
  "private": true,
  "main": "app.js",
  "type": "module",
  "scripts": {
    "build:img": "node minify-images.js",
    "build:scss": "sass ./scss/style.scss ./public/css/style.css --style=expanded --source-map",
    "build:js": "rollup -c",
    "build": "npm-run-all --parallel build:*",
    "start": "node app",
    "start:dev": "npm-run-all --parallel start \"build:* -- --watch\"",
    "test": "npx jest --verbose"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "date-fns": "^2.13.0",
    "debug": "~2.6.9",
    "express": "^4.22.1",
    "hbs": "^4.2.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@babel/core": "^7.17.5",
    "@babel/preset-env": "^7.16.11",
    "@rollup/plugin-babel": "^5.3.1",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "babel-jest": "^30.3.0",
    "imagemin": "^9.0.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-handlebars": "^1.0.1",
    "npm-run-all": "^4.1.5",
    "rollup": "^2.33.3",
    "sass": "^1.49.9"
  },
  "jest": {
    "testURL": "http://localhost:3001",
    "transform": {
      "^.+\\.js$": "babel-jest",
      "\\.hbs$": "jest-handlebars"
    },
    "testEnvironment": "jsdom",
    "transformIgnorePatterns": [],
    "testPathIgnorePatterns": [
      "public"
    ],
    "setupFiles": []
  }
}
